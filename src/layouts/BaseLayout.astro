---
import '../styles/global.css';
import { withBase } from '../lib/format';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'GitHub creator rankings by programming language stars.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="nav">
        <a class="brand" href={withBase('/')}>GitHub Creator Ranking</a>
        <div class="nav-links">
          <a href={withBase('/languages/typescript')}>TypeScript</a>
          <a href={withBase('/countries/china/typescript')}>China</a>
          <a href={withBase('/methodology')}>Methodology</a>
          <a href="https://github.com/formulahendry/github-creator-ranking" target="_blank" rel="noreferrer">
            GitHub
          </a>
        </div>
      </nav>
    </header>
    <main class="main">
      <slot />
    </main>
    <script is:inline>
      const siteHeader = document.querySelector('.site-header');
      const syncSiteHeaderHeight = () => {
        if (!siteHeader) return;
        document.documentElement.style.setProperty(
          '--site-header-height',
          `${siteHeader.getBoundingClientRect().height}px`,
        );
      };

      syncSiteHeaderHeight();
      window.addEventListener('resize', syncSiteHeaderHeight);

      if ('ResizeObserver' in window && siteHeader) {
        new ResizeObserver(syncSiteHeaderHeight).observe(siteHeader);
      }

      const syncRankingTableHeaders = () => {
        document.querySelectorAll('[data-ranking-table]').forEach((table) => {
          const scroller = table.querySelector('.table-wrap');
          const header = table.querySelector('.table-sticky-header');
          if (!scroller || !header || scroller.dataset.headerSync === 'true') return;

          const syncScroll = () => {
            header.scrollLeft = scroller.scrollLeft;
          };

          scroller.dataset.headerSync = 'true';
          scroller.addEventListener('scroll', syncScroll, { passive: true });
          syncScroll();
        });
      };

      syncRankingTableHeaders();
      window.addEventListener('resize', syncRankingTableHeaders);
    </script>
  </body>
</html>
