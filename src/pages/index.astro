---
import BaseLayout from '../layouts/BaseLayout.astro';
import StatCard from '../components/StatCard.astro';
import { formatNumber, withBase } from '../lib/format';
import { getLanguageRanking, getMeta } from '../lib/data';

const meta = getMeta();
const defaultRanking = getLanguageRanking(meta.defaultLanguage);
const topCreator = defaultRanking.items[0];
---

<BaseLayout title="GitHub Creator Ranking">
  <section class="hero">
    <p class="eyebrow">Static rankings for open source creators</p>
    <h1>Rank GitHub creators by language-specific repository stars.</h1>
    <p class="hero-copy">
      Phase 1 tracks TypeScript creators globally and in China. The data pipeline is static and
      designed to expand to more languages and countries.
    </p>
    <div class="hero-actions">
      <a class="button" href={withBase('/languages/typescript')}>View TypeScript ranking</a>
      <a class="button secondary" href={withBase('/methodology')}>Read methodology</a>
    </div>
  </section>

  <section class="stats-grid">
    <StatCard label="Languages" value={formatNumber(meta.languages.length)} hint="Extensible data model" />
    <StatCard label="Countries" value={formatNumber(meta.countries.length)} hint="Location-based approximation" />
    <StatCard label="Default dataset" value={defaultRanking.isPartial ? 'Partial' : 'Complete'} hint="Generated static JSON" />
  </section>

  {
    topCreator && (
      <section class="panel">
        <h2>Current top creator</h2>
        <p>
          <a href={withBase(`/users/${topCreator.login}`)}>{topCreator.name || topCreator.login}</a>
          {' '}has {formatNumber(topCreator.starsPrimary)} primary TypeScript stars in this dataset.
        </p>
      </section>
    )
  }
</BaseLayout>
